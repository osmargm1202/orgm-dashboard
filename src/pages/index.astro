---
import BaseLayout from '../layouts/BaseLayout.astro'
import DashboardShell from '../components/dashboard/DashboardShell.astro'
import runtimeDashboardScript from '../scripts/dashboard-runtime.ts?url'

const runtimeSeed = {
  source: 'loading',
}
---

<BaseLayout
  title="ORGM Dashboard"
  subtitle="Corporate Atlas Command Center"
  serviceCount={0}
  overlayCount={0}
  source={runtimeSeed.source}
>
  <DashboardShell />
  <script id="dashboard-data" type="application/json" is:inline>{JSON.stringify(runtimeSeed).replace(/</g, '\\u003c')}</script>
  <script type="module" src={runtimeDashboardScript} is:inline></script>
</BaseLayout>