---
import Header from '../components/layout/Header.astro'
import Footer from '../components/layout/Footer.astro'
import ThemeTone from '../components/layout/ThemeTone.astro'

interface Props {
  title: string
  subtitle?: string
  serviceCount?: number
  overlayCount?: number
  source?: string
  manifestGeneratedAt?: string
  manifestEnvironment?: string
}

const {
  title,
  subtitle = 'ORGM service dashboard',
  serviceCount,
  overlayCount,
  source = 'mounted',
  manifestGeneratedAt,
  manifestEnvironment,
} = Astro.props as Props
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <style>
      :root {
        color-scheme: dark;
        font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Ubuntu, Cantarell, Noto Sans, sans-serif;
        font-synthesis-weight: none;

        --bg: #05060b;
        --panel: #0c1020;
        --panel-soft: #121a30;
        --panel-line: #1f2a4a;
        --text: #d7e3ff;
        --muted: #8aa0ce;
        --accent: #5ee6ff;
        --accent-strong: #67d9ff;
        --ok: #2cbf72;
        --warn: #ffca6a;
        --bad: #ff6b6b;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100vh;
        background: radial-gradient(circle at 20% 0%, #0f1a38 0%, var(--bg) 60%);
        color: var(--text);
      }

      .app-shell {
        max-width: 1100px;
        margin: 0 auto;
        padding: 1rem 1rem 2.5rem;
      }

      h1,
      h2,
      h3,
      p {
        margin: 0;
      }

      a {
        color: var(--accent);
      }

      .meta-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        align-items: baseline;
        font-size: 0.84rem;
        color: var(--muted);
        margin-top: 0.35rem;
      }

      .section {
        margin-bottom: 1rem;
      }

      .panel {
        border: 1px solid var(--panel-line);
        background: linear-gradient(180deg, rgba(17, 28, 58, 0.78), rgba(12, 16, 32, 0.9));
        border-radius: 0.65rem;
        box-shadow: 0 0 0 1px rgba(94, 230, 255, 0.08);
        padding: 1rem;
      }

      .service-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(230px, 1fr));
        gap: 0.75rem;
        margin-top: 0.85rem;
      }

      .service-card {
        border: 1px solid var(--panel-line);
        background: rgba(12, 16, 32, 0.88);
        border-radius: 0.65rem;
        padding: 0.8rem;
        display: flex;
        flex-direction: column;
        gap: 0.45rem;
      }

      .service-card__header {
        display: flex;
        gap: 0.6rem;
        align-items: center;
      }

      .service-card__logo {
        width: 1.9rem;
        height: 1.9rem;
        border-radius: 0.35rem;
        object-fit: contain;
        background: var(--panel);
      }

      .service-card__initials {
        width: 1.9rem;
        height: 1.9rem;
        border-radius: 0.35rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #14223f;
        border: 1px solid var(--panel-line);
        font-size: 0.7rem;
        font-weight: 700;
        font-family: 'IBM Plex Mono', ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
      }

      .service-card__body {
        display: flex;
        flex-direction: column;
        gap: 0.45rem;
      }

      .status-badge,
      .link-badge,
      .hint-badge {
        width: fit-content;
        border-radius: 999px;
        font-size: 0.73rem;
        padding: 0.12rem 0.5rem;
        border: 1px solid transparent;
      }

      .status-running {
        background: rgba(44, 191, 114, 0.2);
        color: var(--ok);
        border-color: rgba(44, 191, 114, 0.45);
      }

      .status-exited {
        background: rgba(255, 106, 106, 0.2);
        color: var(--bad);
        border-color: rgba(255, 106, 106, 0.45);
      }

      .status-unknown {
        background: rgba(255, 202, 106, 0.18);
        color: var(--warn);
        border-color: rgba(255, 202, 106, 0.45);
      }

      .link-badge {
        background: rgba(94, 230, 255, 0.14);
        color: var(--accent);
        border-color: rgba(94, 230, 255, 0.35);
      }

      .link-badge.badge-internal {
        background: rgba(142, 169, 255, 0.12);
        color: #9eb5ff;
        border-color: rgba(142, 169, 255, 0.4);
      }

      .link-badge.badge-unavailable {
        background: rgba(255, 140, 140, 0.12);
        color: #ffb2b2;
        border-color: rgba(255, 140, 140, 0.4);
      }

      .overlay-editor,
      .service-edit-panel {
        margin-top: 1rem;
      }

      .overlay-editor__panel {
        margin-top: 0.7rem;
      }

      .service-edit-panel {
        border: 1px solid var(--panel-line);
        background: var(--panel);
        padding: 0.7rem;
        border-radius: 0.55rem;
        margin-top: 0.45rem;
      }

      .service-edit-panel label {
        display: grid;
        grid-template-columns: 6.5rem 1fr;
        gap: 0.35rem;
        margin-bottom: 0.4rem;
        font-size: 0.82rem;
        align-items: center;
      }

      .service-edit-panel input,
      .service-edit-panel textarea,
      .service-edit-panel select {
        width: 100%;
        background: #050816;
        color: #dbe4ff;
        border: 1px solid var(--panel-line);
        border-radius: 0.35rem;
        padding: 0.35rem 0.45rem;
      }

      .service-card__actions,
      .overlay-editor__actions {
        display: flex;
        gap: 0.45rem;
        flex-wrap: wrap;
      }

      button,
      .button {
        border: 1px solid var(--panel-line);
        background: #12203f;
        color: #dbe4ff;
        border-radius: 0.35rem;
        padding: 0.32rem 0.65rem;
        font-size: 0.8rem;
        cursor: pointer;
      }

      button:hover {
        border-color: rgba(94, 230, 255, 0.6);
      }

      button:disabled {
        cursor: not-allowed;
        opacity: 0.6;
      }

      .service-card__links {
        display: grid;
        gap: 0.35rem;
      }

      .copyable-snippet {
        border: 1px solid var(--panel-line);
        padding: 0.6rem;
        border-radius: 0.55rem;
        background: #050816;
      }

      pre {
        margin: 0.4rem 0 0;
        padding: 0.55rem;
        border-radius: 0.35rem;
        border: 1px solid var(--panel-line);
        background: #060a14;
        overflow: auto;
        font-size: 0.72rem;
      }

      footer {
        margin-top: 1.5rem;
        color: #7b8cb7;
        font-size: 0.75rem;
      }
    </style>
  </head>
  <body>
    <main class="app-shell">
      <ThemeTone />
      <Header title={title} source={source} />
      <section class="panel section">
        <h1>{title}</h1>
        <p class="meta-row">
          <span>{subtitle}</span>
          {manifestGeneratedAt ? <span>· generated {manifestGeneratedAt}</span> : null}
          <span>· source {source}</span>
          {serviceCount !== undefined ? <span>· services {serviceCount}</span> : null}
          {overlayCount !== undefined ? <span>· overlays <span id="overlay-count">{overlayCount}</span></span> : null}
          {manifestEnvironment ? <span>· env {manifestEnvironment}</span> : null}
        </p>
      </section>
      <slot />
      <Footer generatedAt={manifestGeneratedAt} environment={manifestEnvironment} />
    </main>
  </body>
</html>
