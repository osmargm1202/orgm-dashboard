---
import Header from '../components/layout/Header.astro'
import Footer from '../components/layout/Footer.astro'
import ThemeTone from '../components/layout/ThemeTone.astro'
import '../styles/global.css'

interface Props {
  title: string
  subtitle?: string
  serviceCount?: number
  overlayCount?: number
  source?: string
  manifestGeneratedAt?: string
  manifestEnvironment?: string
}

const {
  title,
  subtitle = 'ORGM service dashboard',
  serviceCount,
  overlayCount,
  source = 'mounted',
  manifestGeneratedAt,
  manifestEnvironment,
} = Astro.props as Props
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

  </head>
  <body>
    <main class="app-shell">
      <ThemeTone />
      <Header title={title} source={source} />
      <section class="panel section">
        <h1>{title}</h1>
        <p class="meta-row">
          <span>{subtitle}</span>
          {manifestGeneratedAt ? <span>· generated {manifestGeneratedAt}</span> : null}
          <span>· source {source}</span>
          {serviceCount !== undefined ? <span>· services {serviceCount}</span> : null}
          {overlayCount !== undefined ? <span>· overlays <span id="overlay-count">{overlayCount}</span></span> : null}
          {manifestEnvironment ? <span>· env {manifestEnvironment}</span> : null}
        </p>
      </section>
      <slot />
      <Footer generatedAt={manifestGeneratedAt} environment={manifestEnvironment} />
    </main>
  </body>
</html>
